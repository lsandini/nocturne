{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.5",
    "body": [
        {
            "type": "Container",
            "style": "emphasis",
            "bleed": true,
            "$when": "${hasAlarm}",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "${alarmMessage}",
                    "weight": "Bolder",
                    "color": "${alarmColor}",
                    "wrap": true
                }
            ]
        },
        {
            "type": "ColumnSet",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "${glucose}",
                            "size": "ExtraLarge",
                            "weight": "Bolder",
                            "color": "${if(hasAlarm, alarmColor, if(stale, 'Attention', 'Default'))}"
                        },
                        {
                            "type": "TextBlock",
                            "text": "${delta}",
                            "size": "Medium",
                            "isSubtle": true,
                            "spacing": "None"
                        }
                    ],
                    "verticalContentAlignment": "Center"
                },
                {
                    "type": "Column",
                    "width": "auto",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "${direction}",
                            "size": "ExtraLarge",
                            "horizontalAlignment": "Center"
                        }
                    ],
                    "verticalContentAlignment": "Center"
                }
            ]
        },
        {
            "type": "Image",
            "url": "${chart}",
            "size": "stretch",
            "spacing": "Small",
            "$when": "${chart != ''}"
        },
        {
            "type": "ColumnSet",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "IOB",
                            "size": "Small",
                            "isSubtle": true
                        },
                        {
                            "type": "TextBlock",
                            "text": "${iob}U",
                            "size": "Medium",
                            "weight": "Bolder",
                            "spacing": "None"
                        }
                    ]
                },
                {
                    "type": "Column",
                    "width": "stretch",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "COB",
                            "size": "Small",
                            "isSubtle": true
                        },
                        {
                            "type": "TextBlock",
                            "text": "${cob}g",
                            "size": "Medium",
                            "weight": "Bolder",
                            "spacing": "None"
                        }
                    ]
                }
            ],
            "spacing": "Medium"
        },
        {
            "type": "ColumnSet",
            "spacing": "Small",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "verticalContentAlignment": "Center",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "Updated ${lastUpdate}",
                            "size": "Small",
                            "isSubtle": true
                        }
                    ]
                },
                {
                    "type": "Column",
                    "width": "auto",
                    "verticalContentAlignment": "Center",
                    "items": [
                        {
                            "type": "Image",
                            "url": "${refreshIcon}",
                            "width": "16px",
                            "altText": "Refresh",
                            "selectAction": { "type": "Action.Execute", "verb": "refresh" }
                        }
                    ]
                }
            ]
        }
    ],
    "selectAction": {
        "type": "Action.Execute",
        "verb": "openApp"
    }
}
