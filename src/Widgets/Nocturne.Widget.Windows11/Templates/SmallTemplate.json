{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.5",
    "body": [
        {
            "type": "Container",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "${glucose}",
                    "size": "ExtraLarge",
                    "weight": "Bolder",
                    "horizontalAlignment": "Center",
                    "color": "${if(hasAlarm, alarmColor, if(stale, 'Attention', 'Default'))}"
                },
                {
                    "type": "TextBlock",
                    "text": "${direction} ${delta}",
                    "size": "Medium",
                    "horizontalAlignment": "Center",
                    "spacing": "None"
                }
            ],
            "verticalContentAlignment": "Center",
            "height": "stretch"
        },
        {
            "type": "ColumnSet",
            "spacing": "Small",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "verticalContentAlignment": "Center",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "${lastUpdate}",
                            "size": "Small",
                            "isSubtle": true
                        }
                    ]
                },
                {
                    "type": "Column",
                    "width": "auto",
                    "verticalContentAlignment": "Center",
                    "items": [
                        {
                            "type": "Image",
                            "url": "${refreshIcon}",
                            "width": "16px",
                            "altText": "Refresh",
                            "selectAction": { "type": "Action.Execute", "verb": "refresh" }
                        }
                    ]
                }
            ]
        }
    ],
    "selectAction": {
        "type": "Action.Execute",
        "verb": "openApp"
    }
}
