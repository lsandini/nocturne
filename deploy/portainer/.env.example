# Nocturne Production Environment
# See: https://github.com/nightscout/nocturne/releases
#
# This file is generated by scripts/publish-release.cs
# Run: dotnet run scripts/publish-release.cs to regenerate before tagging a release.
#
# Copy this file to .env and fill in the required values.

# === Required configuration ===

BASE_DOMAIN=
INSTANCE_KEY=
POSTGRES_USERNAME=nocturne
POSTGRES_PASSWORD=
POSTGRES_MIGRATOR_PASSWORD=
POSTGRES_APP_PASSWORD=
POSTGRES_WEB_PASSWORD=
NOCTURNE_API_IMAGE=ghcr.io/nightscout/nocturne/nocturne-api:latest
NOCTURNE_WEB_IMAGE=ghcr.io/nightscout/nocturne/nocturne-web:latest
NOCTURNE_API_PORT=8080

# === Optional: Discord bot ===
#DISCORD_BOT_TOKEN=
#DISCORD_PUBLIC_KEY=
#DISCORD_APPLICATION_ID=
#DISCORD_CLIENT_SECRET=

# === Optional: Telegram bot ===
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_WEBHOOK_SECRET_TOKEN=

# === Optional: Slack bot ===
#SLACK_BOT_TOKEN=
#SLACK_SIGNING_SECRET=

# === Optional: WhatsApp bot ===
#WHATSAPP_ACCESS_TOKEN=
#WHATSAPP_VERIFY_TOKEN=
#WHATSAPP_APP_SECRET=
#WHATSAPP_PHONE_NUMBER_ID=
