    instance_key:R --> L:nocturne_web
    nocturne_api:R --> L:instance_key
    nocturne_api:R --> L:nocturne_postgres
    nocturne_api:R --> L:nocturne_postgres_server
    nocturne_api:R --> L:postgres_app_password
    nocturne_api:R --> L:postgres_migrator_password
    nocturne_api:R --> L:nocturne_web
    nocturne_api:R --> L:base_domain
